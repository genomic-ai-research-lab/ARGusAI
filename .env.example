ALIGNMENT_TOOL=diamond
DIAMOND_DB_PATH=card_db.dmnd
BLAST_DB_PATH=data/card_db/card.fasta
DIAMOND_THREADS=4
DEFAULT_EVALUE=1e-5
MAX_HITS=5000
UPLOAD_DIR=data/uploads
JOB_STORE_PATH=outputs/job_store.json
OUTPUT_DIR=outputs
LOG_LEVEL=INFO

LLM_PROVIDER=gemini
LLM_MODEL=gemini-3-flash-preview
GEMINI_API_KEY= 
LOCAL_LLM_URL=http://localhost:11434
CARD_API_BASE_URL=https://card.mcmaster.ca/download
IDENTITY_THRESHOLD=55.0
QUERY_COVERAGE_THRESHOLD=60.0
SUBJECT_COVERAGE_THRESHOLD=15.0
FILTER_EVALUE_THRESHOLD=1e-5
MIN_ALIGNMENT_AA=80
FINAL_CONFIDENCE_THRESHOLD=70.0
ALIGN_SCORE_IDENTITY_EXPONENT=1.0
ALIGN_SCORE_COVERAGE_EXPONENT=1.0
ALIGN_SCORE_EVALUE_EXPONENT=1.0
ALIGN_SCORE_EVALUE_LOG_SCALE=5.0
ALIGN_SCORE_IDENTITY_WEIGHT=0.60
ALIGN_SCORE_SCOV_WEIGHT=0.10
ALIGN_SCORE_EVALUE_WEIGHT=0.30
ALIGNMENT_CONFIDENCE_WEIGHT=0.7
LLM_CONFIDENCE_WEIGHT=0.3
PIPELINE_VERSION=2.1.0
CALIBRATION_MODEL_PATH=

LLM_TIMEOUT_SECONDS=20
LLM_MAX_RETRIES=2
LLM_RATE_LIMIT_PER_MINUTE=120
LLM_PARALLELISM=4
LLM_BATCH_SIZE=5

API_RATE_LIMIT_PER_MINUTE=120
MAX_UPLOAD_SIZE_BYTES=10485760
RETRIEVAL_PARALLELISM=8
CHROMA_INDEX_BATCH_SIZE=256

BENCHMARK_ENABLED=false
BENCHMARK_TRUTH_PATH=data/benchmark/sample_truth.json
BENCHMARK_OUTPUT_PATH=outputs/benchmark/benchmark_metrics.json
BENCHMARK_DATASET_NAME=sample-benchmark
BENCHMARK_BASELINE_NAME=card-baseline
